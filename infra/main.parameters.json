{
    "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
        "environmentName": { "value": "${AZURE_ENV_NAME}" },
        "location": { "value": "${AZURE_LOCATION}" },
        "principalId": { "value": "${AZURE_PRINCIPAL_ID}" },
        "chatGptDeploymentName": { "value": "${AZURE_OPENAI_CHATGPT_DEPLOYMENT=gpt-4.1-mini}" },
        "chatGptModelName": { "value": "${AZURE_OPENAI_CHATGPT_MODEL=gpt-4.1-mini}" },
        "chatGptModelVersion": { "value": "${AZURE_OPENAI_CHATGPT_MODEL_VERSION=2025-04-14}" },
        "embeddingDeploymentName": { "value": "${AZURE_OPENAI_EMB_DEPLOYMENT=text-embedding-3-large}" },
        "embeddingModelName": { "value": "${AZURE_OPENAI_EMB_MODEL=text-embedding-3-large}" },
        "searchIndexName": { "value": "${AZURE_SEARCH_INDEX=rag-index}" },
        "useMultimodal": { "value": "${USE_MULTIMODAL=false}" },
        "useGraphRag": { "value": "${USE_GRAPHRAG=true}" },
        "useVerifier": { "value": "${USE_VERIFIER=true}" },
        "useVoiceDemo": { "value": "${USE_VOICE_DEMO=true}" },
        "useSqlDemo": { "value": "${USE_SQL_DEMO=true}" },
        "useContentSafety": { "value": "${USE_CONTENT_SAFETY=false}" },
        "useFeedback": { "value": "${USE_FEEDBACK=true}" },
        "rateLimitPerMin": { "value": "${RATE_LIMIT_PER_MIN=30}" },
        "maxTokensPerSession": { "value": "${MAX_TOKENS_PER_SESSION=200000}" },
        "openaiFileSearchVectorStoreId": { "value": "${OPENAI_FILE_SEARCH_VECTOR_STORE_ID=}" },
        "langsmithProject": { "value": "${LANGSMITH_PROJECT=multimodal-rag}" }
    }
}
